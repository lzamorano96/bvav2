{
  "_comment": "Field definitions + validation rules consumed by dataIngestion.js (M1).",
  "fields": {
    "unitsSold":     { "type": "integer", "min": 0, "required": true, "default": 500 },
    "unitPrice":     { "type": "number",  "min": 0, "required": true, "default": 59 },
    "refundRate":    { "type": "percent", "min": 0, "max": 1, "required": true, "default": 0.15 },
    "costPerCredit": { "type": "number",  "min": 0, "required": true, "default": 0.04 },
    "upfrontCredits":{ "type": "integer", "min": 0, "required": true, "default": 100 },
    "monthlyCredits":{ "type": "integer", "min": 0, "required": true, "default": 25 },
    "activeUsers":   { "type": "integer", "min": 0, "required": true, "default": 400 }
  },
  "note": "Rev-share tiers and marketing valuation rates default from benchmarks.json but may be overridden in-UI when config.featureFlags.editableBenchmarks is true."
}
